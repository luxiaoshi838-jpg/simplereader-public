<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2EFE6"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="18dp"
    android:paddingEnd="16dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/shelfTabTextView"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="书架"
            android:textColor="#24211C"
            android:textSize="27sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/historyTabTextView"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="24dp"
            android:gravity="center_vertical"
            android:text="阅读历史"
            android:textColor="#9A958B"
            android:textSize="21sp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/searchButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:text="⌕"
            android:textColor="#24211C"
            android:textSize="33sp" />

        <TextView
            android:id="@+id/moreButton"
            android:layout_width="38dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:text="⋮"
            android:textColor="#24211C"
            android:textSize="30sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="7dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/readingStatsTextView"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:background="@drawable/bg_shelf_stat"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:paddingStart="10dp"
            android:paddingEnd="8dp"
            android:text="累计导入 0 本"
            android:textColor="#77736A"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/exportButton"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="数据导出"
            android:textColor="#36322B"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/importButton"
            android:layout_width="52dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="导入"
            android:textColor="#36322B"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/editButton"
            android:layout_width="52dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="编辑"
            android:textColor="#36322B"
            android:textSize="15sp" />
    </LinearLayout>

    <com.simplereader.app.ui.FastScrollView
        android:id="@+id/shelfScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <GridLayout
            android:id="@+id/shelfGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:paddingEnd="14dp"
            android:useDefaultMargins="false" />
    </com.simplereader.app.ui.FastScrollView>
</LinearLayout>
